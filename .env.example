# NeuroGrid Environment Variables
# Copy this file to .env and fill in your values

# Application password (SHA-256 hash of your chosen password)
# Default hash below = SHA-256("neurogrid")
APP_PASSWORD_HASH=d6c3cf48e43daa7c6d14e6e3883af26e3d053a4684229f888880f3097dcdf45f

# Database (Phase 3)
DATABASE_URL=postgresql://user:password@localhost:5432/neurogrid

# JWT Secret (Phase 3 auth)
SECRET_KEY=your-super-secret-key-change-this

# Anthropic API Key (Phase 4 AI suggestions)
ANTHROPIC_API_KEY=sk-ant-...

# Server
HOST=0.0.0.0
PORT=8000
